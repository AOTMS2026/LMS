{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://loyola-lms.onrender.com/api",
    "VITE_RENDER_URL": "https://loyola-lms.onrender.com",
    "VITE_ZOOM_CLIENT_ID": "NjmbRGboS82PrvvlTnDJcA"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}